                      if ($eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip3,2)) $+ .curhp,2) > 0) { dec $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip3,2)) $+ .curhp,1) %mmbca.dmgcalc.result | echo 8 -s - hit $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip3,2)),2) ( $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip3,2)) $+ .curhp,2) $+ / $+ $read(battlechips\ $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip3,2)),2) $+ .txt,1) $+ ) }
                      if ($eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip2,2)) $+ .curhp,2) > 0) { dec $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip2,2)) $+ .curhp,1) %mmbca.dmgcalc.result | echo 8 -s - hit $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip2,2)),2) ( $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip2,2)) $+ .curhp,2) $+ / $+ $read(battlechips\ $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip2,2)),2) $+ .txt,1) $+ ) }
                      if ($eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip1,2)) $+ .curhp,2) > 0) { dec $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip1,2)) $+ .curhp,1) %mmbca.dmgcalc.result | echo 8 -s - hit $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip1,2)),2) ( $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip1,2)) $+ .curhp,2) $+ / $+ $read(battlechips\ $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker $+ .chip1,2)),2) $+ .txt,1) $+ ) }
                    }
                    elseif ($v1 = 4) {
                      var %mmbca.battle.rand.multi 1
                      while (%mmbca.battle.rand.multi !> %mmbca.dmgcalc.hits) {
                        var %mmbca.battle.randdmg $rand(1,3)
                        var %mmbca.battle.randdmg.target % $+ %mmbca.battle.attacker $+ .chip $+ %mmbca.battle.randdmg
                        if ($eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2) $+ .curhp,2) > 0) { dec $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2) $+ .curhp,1) $calc(%mmbca.dmgcalc.result / %mmbca.dmgcalc.hits ) | echo 8 -s - hit $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2),2) ( $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2) $+ .curhp,2) $+ / $+ $read(battlechips\ $+ $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2),2) $+ .txt,1) $+ ) }
                        else { echo 4 -s Targeted empty slot }
                        inc %mmbca.battle.rand.multi
                      }
                    }
                    elseif ($v1 = 5) {
                      var %mmbca.battle.rand.multi 1
                      while (%mmbca.battle.rand.multi !> %mmbca.dmgcalc.hits) {
                        var %mmbca.battle.randdmg $rand(1,3)
                        if (%mmbca.battle.randdmg > 0) { var %mmbca.battle.randdmg.target % $+ %mmbca.battle.attacker $+ .chip $+ %mmbca.battle.randdmg }
                        if ($eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval($eval(% $+ %mmbca.battle.attacker) $+ .chip $+ %mmbca.battle.randdmg) $+ .curhp,2) > 0) { set $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2) $+ .curhp,1) 0 | echo 8 -s - deleted $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slot $+ $eval(%mmbca.battle.randdmg.target,2),2) }
                        else { echo 4 -s Targeted empty slot }
                        inc %mmbca.battle.rand.multi
                      }
                    }
                    elseif ($v1 = 6) && (%mmbca.battle.target = $eval(% $+ %mmbca.battle.attacker) $+ .navi) {
                      var $eval(% $+ %mmbca.battle.attacker) $+ .slotL.curhp 0 | echo 8 -s - deleted $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slotL,2)
                      var $eval(% $+ %mmbca.battle.attacker) $+ .slotR.curhp 0 | echo 8 -s - deleted $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's $eval(% $+ %mmbca.battle.attacker $+ .slotR,2)
                    }
                    unset $eval(% $+ %mmbca.battle.defender) $+ .chipdmg
                  }
                  if ($eval($eval(% $+ %mmbca.battle.attacker $+ .box,2) $+ .curhp,2) <= 0) { echo 13 -s $eval($eval(% $+ %mmbca.battle.attacker $+ .box,3)) removed from $eval(% $+ %mmbca.battle.attacker $+ .navi.name,2) $+ 's box! | set $eval(% $+ %mmbca.battle.attacker) $+ .box 0 }
                  checkdel
                }
                else { echo 7 $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ 's attack missed! %mmbca.battle.acc vs %mmbca.battle.dodge }
                if ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,12) = 1) && (%mmbca.battle.field = 3) { set %mmbca.battle.field 0 | echo 15 -s Stage: Basic }
                elseif ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,12) = 2) && (%mmbca.battle.field = 1) { set %mmbca.battle.field 0 | echo 15 -s Stage: Basic }
                elseif ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,12) = 4) && (%mmbca.battle.field = 4) { set %mmbca.battle.field 3 | echo 9 -s Stage: Grass }
              }
              unset %mmbca.battle.counter
              if ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,22) = 1) { echo 13 -s $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) removed from $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's box! | set $eval(% $+ %mmbca.battle.defender) $+ .box 0 }
              elseif ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,22) = 2) {
                echo 13 -s $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) was deleted!
                set $eval($eval(% $+ %mmbca.battle.defender $+ .box,2)) $+ .curhp 0
                echo 13 -s $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) removed from $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's box!
                set $eval(% $+ %mmbca.battle.defender) $+ .box 0
              }
            }
            if (.box isin %mmbca.battle.target) && ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,22) = 1) { echo 13 -s $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) removed from $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's box! | set $eval(% $+ %mmbca.battle.defender) $+ .box 0 }
            elseif (.box isin %mmbca.battle.target) && ($read(battlechips\ $+ $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) $+ .txt,22) = 2) {
              echo 13 -s $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) was deleted!
              set $eval($eval(% $+ %mmbca.battle.defender $+ .box,2)) $+ .curhp 0
              echo 13 -s $eval($eval(% $+ %mmbca.battle.defender $+ .box,3)) removed from $eval(% $+ %mmbca.battle.defender $+ .navi.name,2) $+ 's box!
              set $eval(% $+ %mmbca.battle.defender) $+ .box 0
            }
            if ($eval(% $+ %mmbca.battle.attacker $+ .box,3)) { echo 13 -s Removed $eval(% $+ %mmbca.battle.attacker $+ .box,3) from $eval(% $+ %mmbca.battle.attacker $+ .navi.name,3) $+ 's box }
            set $eval(% $+ %mmbca.battle.attacker) $+ .box 0
            if (%mmbca.battle.priority = 1) { set %mmbca.battle.priority 2 }
            else { set %mmbca.battle.priority 1 }
            inc %mmbca.battle.chip
          }
        }
      }
    }
    unset %mmbca.battle.eot
    unset %mmbca.battle.eot.clock
    unset %mmbca.battle.priority

    if (%mmbca.battle.field = 1) && ($read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,2) != 1) {
      dec %mmbca.battle.p1.navi.curhp 50
      if (%mmbca.battle.p1.navi.curhp <= 0) { set %mmbca.battle.p1.navi.curhp 10 }
      echo 4 -s Fire from stage sprayed %mmbca.battle.p1.navi.name $+ !
    }
    if (%mmbca.battle.field = 1) && ($read(navichips\ $+ %mmbca.battle.p2.navi $+ .txt,2) != 1) {
      dec %mmbca.battle.p2.navi.curhp 50
      if (%mmbca.battle.p2.navi.curhp <= 0) { set %mmbca.battle.p2.navi.curhp 10 }
      echo 4 -s Fire from stage sprayed %mmbca.battle.p2.navi.name $+ !
    }
    if (%mmbca.battle.field = 3) && ($read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,2) = 4) {
      inc %mmbca.battle.p1.navi.curhp 50
      if (%mmbca.battle.p1.navi.curhp > $read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,1)) { set %mmbca.battle.p1.navi.curhp $read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,1) }
      echo 9 -s Earth energy from stage healed %mmbca.battle.p1.navi.name $+ !
    }
    if (%mmbca.battle.field = 3) && ($read(navichips\ $+ %mmbca.battle.p2.navi $+ .txt,2) = 4) {
      inc %mmbca.battle.p2.navi.curhp 50
      if (%mmbca.battle.p2.navi.curhp > $read(navichips\ $+ %mmbca.battle.p2.navi $+ .txt,1)) { set %mmbca.battle.p2.navi.curhp $read(navichips\ $+ %mmbca.battle.p2.navi $+ .txt,1) }
      echo 9 -s Earth energy from stage healed %mmbca.battle.p2.navi.name $+ !
    }
    if (%mmbca.battle.field = 5) {
      echo 6 -s Poison gas rose from stage!
      dec %mmbca.battle.p1.navi.curhp 20
      checkdel
      if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p1.navi.name $+ 's $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3),2) }
      if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p1.navi.name $+ 's $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2),2) }
      if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip1) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip1) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p1.navi.name $+ 's $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip1),2) }
      dec %mmbca.battle.p2.navi.curhp 20
      checkdel
      if ($eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip3) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip3) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p2.navi.name $+ 's $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip3),2) }
      if ($eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip2) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip2) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p2.navi.name $+ 's $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip2),2) }
      if ($eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip1) $+ .curhp,2) > 0) { dec $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip1) $+ .curhp,1) 20 | echo 8 -s - hit %mmbca.battle.p2.navi.name $+ 's $eval(% $+ mmbca.battle.p2.slot $+ $eval(%mmbca.battle.p2.chip1),2) }
      checkdel
    }
    unset %mmbca.battle.p1.stun
    unset %mmbca.battle.p2.stun
    unset %mmbca.battle.p1.back
    unset %mmbca.battle.p2.back
    set %mmbca.battle.p1.box 0
    set %mmbca.battle.p2.box 0
    set %mmbca.battle.p1.boost 0
    set %mmbca.battle.p2.boost 0
    set %mmbca.battle.p1.navi.boost 0
    set %mmbca.battle.p2.navi.boost 0
    if (%mmbca.battle.turn = 10) { echo 4 -s TIME UP | unset %mmbca.battle | halt }
    inc %mmbca.battle.turn
  }
}
/dmgcalc {
  ; if (%mmbca.battle.eot = 1) { echo 4 -s Priority is %mmbca.battle.priority }
  set %mmbca.dmgcalc.source 0
  set %mmbca.dmgcalc.hits 0

  set %mmbca.dmgcalc.bonus.stab 0
  set %mmbca.dmgcalc.bonus.weak 0
  set %mmbca.dmgcalc.bonus.tile 0

  set %mmbca.dmgcalc.p1.empty 0
  set %mmbca.dmgcalc.p2.empty 0
  if ($eval(% $+ mmbca.battle.p1.slot $+ %mmbca.battle.p1.chip1 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p1.empty }
  if ($eval(% $+ mmbca.battle.p1.slot $+ %mmbca.battle.p1.chip2 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p1.empty }
  if ($eval(% $+ mmbca.battle.p1.slot $+ %mmbca.battle.p1.chip3 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p1.empty }
  if ($eval(% $+ mmbca.battle.p2.slot $+ %mmbca.battle.p2.chip1 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p2.empty }
  if ($eval(% $+ mmbca.battle.p2.slot $+ %mmbca.battle.p2.chip2 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p2.empty }
  if ($eval(% $+ mmbca.battle.p2.slot $+ %mmbca.battle.p2.chip3 $+ .curhp,2) !> 0) { inc %mmbca.dmgcalc.p2.empty }

  if (.slot !isin %mmbca.battle.target) && (.box !isin %mmbca.battle.target) { set %mmbca.dmgcalc.target navi }
  else { set %mmbca.dmgcalc.target battle }
  ; echo 4 -s DEBUG: $v1 $v2
  if (%mmbca.battle.counter) && (%mmbca.battle.priority = 1) { set %mmbca.dmgcalc.source $eval(%mmbca.battle.p2.box,2) | set %mmbca.dmgcalc.target navi | set %mmbca.dmgcalc.folder battle | goto p2counter }
  elseif (%mmbca.battle.counter) && (%mmbca.battle.priority = 2) { set %mmbca.dmgcalc.source $eval(%mmbca.battle.p1.box,2) | set %mmbca.dmgcalc.target navi | set %mmbca.dmgcalc.folder battle | goto p1counter }
  if (%mmbca.battle.priority = 1) {
    if (!%mmbca.battle.counter) {
      ; if (.navi isin %mmbca.battle.p2.box) { set %mmbca.dmgcalc.target navi }
      if (%mmbca.battle.turn.navi = 1) { set %mmbca.dmgcalc.source %mmbca.battle.p1.navi | set %mmbca.dmgcalc.folder navi }
      elseif (%mmbca.battle.eot = 1) { set %mmbca.dmgcalc.source $eval(%mmbca.battle.p1.box,4) | set %mmbca.dmgcalc.folder battle }
      else { set %mmbca.dmgcalc.source $eval(%mmbca.battle.p1.active.slot,2) | set %mmbca.dmgcalc.folder battle }
    }

    :p1counter
    set %mmbca.dmgcalc.base $calc($read(%mmbca.dmgcalc.folder $+ chips\ $+ $eval(%mmbca.dmgcalc.source) $+ .txt,6) + %mmbca.battle.p1.boost)
    if ($read(battlechips\ $+ $eval(%mmbca.battle.p1.box,2) $+ .txt,31) = 8) { inc %mmbca.dmgcalc.base $read(battlechips\ $+ $eval(%mmbca.battle.p1.box,2) $+ .txt,6) }
    ; echo 4 -s DEBUG: $v1 $eval(%mmbca.battle.p1.box,2)
    set %mmbca.battle.p1.boost 0
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 1) && (%mmbca.battle.p1.active.ball > $read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,6)) { set %mmbca.dmgcalc.base %mmbca.battle.p1.active.ball }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 2) && (%mmbca.battle.p1.active.dmgdealt > $read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,6)) { set %mmbca.dmgcalc.base %mmbca.battle.p1.active.dmgdealt }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 3) {
      if (%mmbca.battle.global.chip = 1) {
        if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2) $+ .curhp,2) > 0) && ($read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2),2) $+ .txt,15) > 0) { inc %mmbca.dmgcalc.base $read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip2),2) $+ .txt,6) }
        if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3) $+ .curhp,2) > 0) && ($read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3),2) $+ .txt,15) > 0) { inc %mmbca.dmgcalc.base $read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3),2) $+ .txt,6) }
      }
      elseif (%mmbca.battle.global.chip = 2) {
        if ($eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3) $+ .curhp,2) > 0) && ($read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3),2) $+ .txt,15) > 0) { inc %mmbca.dmgcalc.base $read(battlechips\ $+ $eval(% $+ mmbca.battle.p1.slot $+ $eval(%mmbca.battle.p1.chip3),2) $+ .txt,6) }
      }
    }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 4) && (%mmbca.battle.field = 1) { set %mmbca.dmgcalc.base $calc(%mmbca.dmgcalc.base *2) | set %mmbca.battle.field 0 | echo 15 -s Stage: Basic }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 5) { set %mmbca.dmgcalc.base $calc(%mmbca.dmgcalc.base * %mmbca.battle.p1.dodgedown /10) }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 6) { set %mmbca.dmgcalc.base $calc(%mmbca.dmgcalc.base * 2^ %mmbca.battle.p1.counter) }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 7) { set %mmbca.dmgcalc.base $calc(%mmbca.dmgcalc.base * (%mmbca.dmgcalc.p1.empty - %mmbca.dmgcalc.p2.empty)) }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 8) { set %mmbca.dmgcalc.base $calc(%mmbca.dmgcalc.base * %mmbca.battle.turn) }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 9) && (%mmbca.battle.p1.navi.curhp < $read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,1)) { set %mmbca.dmgcalc.base $calc($read(navichips\ $+ %mmbca.battle.p1.navi $+ .txt,1) - %mmbca.battle.p1.navi.curhp) }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 10) {
      if ($rand(1,4) = 1) { set %mmbca.dmgcalc.base 70 }
      elseif ($v1 = 2) { set %mmbca.dmgcalc.base 80 }
      elseif ($v1 = 3) { set %mmbca.dmgcalc.base 90 }
      elseif ($v1 = 4) { set %mmbca.dmgcalc.base 180 }
    }
    if ($read(%mmbca.dmgcalc.folder $+ chips\ $+ %mmbca.dmgcalc.source $+ .txt,23) = 11) {
